    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: d13703b8eb2847a478471acc9e004a9d, type: 3}
    m_FontSize: 32
    m_FontStyle: 0
    m_BestFit: 1
    m_MinSize: 20
    m_MaxSize: 32
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u0418\u0434\u0438 \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u043F\u0435\u0440\u0435\u0434
    \u0438 \u0441\u0440\u0430\u0436\u0430\u0439\u0441\u044F \u0441 \u0432\u0440\u0430\u0433\u0430\u043C\u0438!\n\u0441\u043B\u0435\u0434\u0438
    \u0437\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C. \u0422\u0430\u043A\u0436\u0435
    \u0435\u0441\u0442\u044C \u043C\u0430\u0433\u0430\u0437\u0438\u043D, \u0433\u0434\u0435
    \u0437\u0430 \u043C\u043E\u043D\u0435\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u044B\u043F\u0430\u043B\u0438 \u0441 \u0432\u0440\u0430\u0433\u043E\u0432
    \u043C\u043E\u0436\u043D\u043E \u043A\u0443\u043F\u0438\u0442\u044C \u0432\u0435\u0449\u0438
    \u0438\u043B\u0438 \u0443\u0441\u0438\u043B\u0438\u0442\u044C\u0441\u044F.\n\u041D\u0430
    \u043F\u0443\u0442\u0438 \u0442\u0430\u043A\u0436\u0435 \u043C\u043E\u0433\u0443\u0442
    \u043F\u043E\u043F\u0430\u0441\u0442\u044C\u0441\u044F \u0441\u0443\u043D\u0434\u0443\u043A\u0438
    \u0441 \u043C\u043E\u043D\u0435\u0442\u0430\u043C\u0438, \u043D\u0435 \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u0439
    \u0438\u0445! \u0423\u0414\u0430\u0447\u0438!"
