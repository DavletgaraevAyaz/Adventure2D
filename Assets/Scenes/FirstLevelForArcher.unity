  m_FontData:
    m_Font: {fileID: 12800000, guid: d13703b8eb2847a478471acc9e004a9d, type: 3}
    m_FontSize: 32
    m_FontStyle: 0
    m_BestFit: 1
    m_MinSize: 20
    m_MaxSize: 32
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u041F\u0440\u0438\u0432\u0435\u0442, \u041B\u0443\u0447\u043D\u0438\u043A!
    \u041B\u0435\u0442\u0443\u0447\u0438\u0435 \u0433\u043B\u0430\u0437\u0430 \u0438
    \u0433\u043E\u0431\u043B\u0438\u043D\u044B \u043D\u0430\u0447\u0438\u043D\u0430\u044E\u0442
    \u0432\u044B\u0431\u0438\u0440\u0430\u0442\u044C\u0441\u044F \u0438\u0437 \u043F\u0435\u0449\u0435\u0440.
    \u041E\u0441\u0442\u0430\u043D\u043E\u0432\u0438 \u0438\u0445 \u0438 \u0443\u0433\u0440\u043E\u0437\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D\u0438 \u043D\u0435\u0441\u0443\u0442!\n\u041D\u043E
    \u0431\u0443\u0434\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D!
    \u0423 \u043D\u0438\u0445 \u0435\u0441\u0442\u044C \u043F\u0440\u0435\u0434\u0432\u043E\u0434\u044F\u0449\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0447\u0435\u043D\u044C \u0441\u0438\u043B\u044C\u043D\u044B."
